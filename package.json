{
  "name": "nuxt-frontend-template",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "pnpm run build && wrangler pages dev",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "ci": "pnpm typecheck && pnpm lint && pnpm build",
    "deploy": "pnpm run build && wrangler pages deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^10.2.4",
    "@pinia/nuxt": "^0.11.3",
    "crypto-es": "^3.1.3",
    "es-toolkit": "^1.45.1",
    "nuxt": "^4.4.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@eslint/css": "^1.1.0",
    "@html-eslint/parser": "^0.59.0",
    "@iconify/utils": "^3.1.0",
    "@kikiutils/eslint-config": "^9.0.0",
    "@kikiutils/eslint-plugin-vue": "^10.2.2",
    "@types/node": "^25.5.2",
    "@unocss/nuxt": "^66.6.8",
    "@unocss/transformer-directives": "^66.6.8",
    "@vue/language-core": "^3.2.6",
    "eslint": "^10.2.1",
    "eslint-plugin-better-tailwindcss": "^4.4.1",
    "eslint-plugin-format": "^2.0.1",
    "h3": "2.0.1-rc.20",
    "nitro-cloudflare-dev": "^0.2.2",
    "postcss-pxtorem": "^6.1.0",
    "sass-embedded": "^1.99.0",
    "tailwind-csstree": "^0.3.1",
    "tailwindcss": "^4.2.2",
    "unocss": "^66.6.8",
    "vue-eslint-parser": "^10.4.0",
    "wrangler": "^4.80.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp",
      "workerd"
    ]
